# ──────────────────────────────────────────────────────────────────────────────
# Quirk TMS — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Generate strong JWT secrets with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# ──────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://quirk_admin:your_password@quirk-db.postgres.database.azure.com:5432/postgres?sslmode=require
# TLS certificate verification is ON by default (recommended). Set to "false" only
# as a temporary escape hatch if a trusted CA chain is genuinely unavailable.
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# ─── Authentication (REQUIRED — server will not start without these) ─────────
# Must be cryptographically strong random strings (min 48 bytes recommended)
JWT_SECRET=CHANGE_ME_generate_with_crypto_randomBytes
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_crypto_randomBytes

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Azure Blob Storage (optional — for production file uploads) ─────────────
# AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_BLOB_CONTAINER_NAME=taskflow-attachments

# ─── Azure Communication Services Email (optional — for production emails) ───
# AZURE_ACS_CONNECTION_STRING=endpoint=https://...;accesskey=...
# AZURE_ACS_SENDER_ADDRESS=DoNotReply@your-id.azurecomm.net

# ─── AI Assistant (optional) ─────────────────────────────────────────────────
# Providers are tried in priority order with automatic fallback: Gemini first,
# then Groq. Set at least one API key to enable the assistant; if none is set,
# the /api/ai/chat endpoint returns 503 and the rest of the app is unaffected.
# Google Gemini — https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# Groq (fallback) — https://console.groq.com/keys
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
