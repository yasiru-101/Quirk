// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ─── Workspace Model ──────────────────────────────────────────────────────────
// Top-level organisation container. Created during PM/Admin onboarding.
model Workspace {
  id          String   @id @default(uuid())
  name        String
  description String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  owner         User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members       WorkspaceMember[]
  projects      Project[]
  invitations   Invitation[]
  conversations Conversation[]
}

// ─── WorkspaceMember Model (Many-to-Many Join Table) ─────────────────────────
// A user's role is scoped to the workspace, not global:
//   Owner  — the creator; full control, cannot be removed while sole owner.
//   Admin  — can manage members, invitations and projects.
//   Member — can participate in projects they belong to.
model WorkspaceMember {
  workspaceId String
  userId      String
  role        String   @default("Member") // Owner, Admin, Member
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
}

// ─── Invitation Model ─────────────────────────────────────────────────────────
// A tokenised invitation to join a workspace. The raw token is emailed to the
// recipient and only its hash is stored, so a database leak cannot be replayed.
model Invitation {
  id          String    @id @default(uuid())
  workspaceId String
  email       String
  role        String    @default("Member") // workspace role granted on acceptance
  tokenHash   String    @unique
  invitedBy   String
  status      String    @default("pending") // pending, accepted, revoked
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inviter   User      @relation("InvitationInviter", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([email])
}

// ─── OtpCode Model ──────────────────────────────────────────────────────────
// One-time codes for email verification and login 2FA. Only the bcrypt hash of the
// code is stored, never the code itself. Codes are single-use, time-limited, and
// attempt-limited.
model OtpCode {
  id         String    @id @default(uuid())
  userId     String
  codeHash   String
  purpose    String // EMAIL_VERIFY, LOGIN_2FA
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
}

// ─── User Model ──────────────────────────────────────────────────────────────
model User {
  id                String  @id @default(uuid())
  name              String
  email             String  @unique
  passwordHash      String
  role              String  @default("Collaborator") // Admin, Project Manager, Collaborator
  mustResetPassword Boolean @default(true)
  isActive          Boolean @default(true)

  // Identity verification & MFA. emailVerified defaults true so administrator-created
  // and pre-existing accounts are trusted; self-registration explicitly sets it false
  // until the email is confirmed via a one-time code.
  emailVerified    Boolean @default(true)
  twoFactorEnabled Boolean @default(false)

  // Extended profile fields (SRS §Onboarding)
  avatarUrl          String?
  jobTitle           String?
  timezone           String?
  onboardingComplete Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  ownedWorkspaces          Workspace[]               @relation("WorkspaceOwner")
  workspaceMemberships     WorkspaceMember[]
  invitationsSent          Invitation[]              @relation("InvitationInviter")
  projectsCreated          Project[]                 @relation("ProjectCreator")
  projectMemberships       ProjectMember[]
  tasksCreated             Task[]                    @relation("TaskCreator")
  assignments              TaskAssignment[]
  comments                 Comment[]
  attachments              Attachment[]
  notifications            Notification[]
  timeLogs                 TimeLog[]
  activityLogs             ActivityLog[]
  otpCodes                 OtpCode[]
  conversationParticipants ConversationParticipant[]
  chatMessages             ChatMessage[]
}

// ─── Project Model ───────────────────────────────────────────────────────────
model Project {
  id           String    @id @default(uuid())
  name         String
  description  String?
  workspaceId  String?
  createdBy    String
  status       String    @default("active") // active, archived
  templateType String? // Legacy: "Software Development", "Marketing Campaign", "Basic Kanban"
  templateId   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Relations
  workspace    Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  creator      User            @relation("ProjectCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  template     ProjectTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  members      ProjectMember[]
  tasks        Task[]
  columns      KanbanColumn[]
  epics        Epic[]
  conversation Conversation?
}

// ─── ProjectTemplate Model ───────────────────────────────────────────────────
model ProjectTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  columns     ProjectTemplateColumn[]
  projects    Project[]
}

// ─── ProjectTemplateColumn Model ─────────────────────────────────────────────
model ProjectTemplateColumn {
  id         String   @id @default(uuid())
  templateId String
  name       String
  order      Int      @default(0)

  template   ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, order])
}

// ─── ProjectMember Model (Many-to-Many Join Table) ───────────────────────────
model ProjectMember {
  projectId String
  userId    String
  role      String   @default("Collaborator") // Project Manager, Collaborator
  addedAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

// ─── KanbanColumn Model ───────────────────────────────────────────────────────
// Custom workflow columns per project (SRS §Custom Workflows).
model KanbanColumn {
  id        String   @id @default(uuid())
  projectId String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId, order])
}

// ─── Epic Model ───────────────────────────────────────────────────────────────
// Broad categories grouping related tasks (SRS §Tags & Epics).
model Epic {
  id        String   @id @default(uuid())
  projectId String
  name      String
  color     String? // Accent hex color for UI display
  createdAt DateTime @default(now())

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
}

// ─── Task Model ──────────────────────────────────────────────────────────────
model Task {
  id          String  @id @default(uuid())
  title       String
  description String?
  projectId   String?
  createdBy   String

  // Workflow positioning
  columnId String? // FK to KanbanColumn; null = ungrouped

  // Task attributes (SRS)
  dueDate        DateTime?
  priority       String    @default("Medium") // Low, Medium, High, Urgent
  tags           String[]  @default([])
  epicId         String? // FK to Epic
  estimatedHours Float? // SRS §Time Tracking

  // Subtask support (self-relation)
  parentTaskId String? // null = top-level task; set = subtask

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  project       Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  column        KanbanColumn?    @relation(fields: [columnId], references: [id], onDelete: SetNull)
  epic          Epic?            @relation(fields: [epicId], references: [id], onDelete: SetNull)
  creator       User             @relation("TaskCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  parent        Task?            @relation("Subtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks      Task[]           @relation("Subtasks")
  assignments   TaskAssignment[]
  comments      Comment[]
  attachments   Attachment[]
  notifications Notification[]
  timeLogs      TimeLog[]
  activityLogs  ActivityLog[]

  // Dependency relations
  blocking  TaskDependency[] @relation("BlockingTask")
  blockedBy TaskDependency[] @relation("BlockedTask")

  @@index([projectId])
  @@index([parentTaskId])
}

// ─── TaskDependency Model ────────────────────────────────────────────────────
// Stores "Task A blocks Task B" relationships (SRS §Task Dependencies).
model TaskDependency {
  id             String   @id @default(uuid())
  blockingTaskId String // The task that is blocking
  blockedTaskId  String // The task that is blocked
  createdAt      DateTime @default(now())

  blockingTask Task @relation("BlockingTask", fields: [blockingTaskId], references: [id], onDelete: Cascade)
  blockedTask  Task @relation("BlockedTask", fields: [blockedTaskId], references: [id], onDelete: Cascade)

  @@unique([blockingTaskId, blockedTaskId])
}

// ─── TaskAssignment Model (Many-to-Many Join Table) ──────────────────────────
model TaskAssignment {
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

// ─── TimeLog Model ────────────────────────────────────────────────────────────
// Records actual time spent on a task (SRS §Time Tracking).
model TimeLog {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  hours     Float
  date      DateTime @default(now())
  note      String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// ─── ActivityLog Model ────────────────────────────────────────────────────────
// Automated audit trail per task (SRS §Activity Log).
model ActivityLog {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  action    String // e.g. "column_changed", "assigned", "commented", "subtask_added"
  metadata  Json? // { from, to, comment, assigneeName, etc. }
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

// ─── Comment Model ───────────────────────────────────────────────────────────
model Comment {
  id        String    @id @default(uuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  task        Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  attachments Attachment[]
}

// ─── Attachment Model ────────────────────────────────────────────────────────
model Attachment {
  id           String   @id @default(uuid())
  taskId       String
  commentId    String?
  uploadedBy   String
  originalName String
  blobUrl      String
  mimeType     String?
  sizeBytes    Int
  createdAt    DateTime @default(now())

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  comment  Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  uploader User     @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)
}

// ─── Notification Model ──────────────────────────────────────────────────────
model Notification {
  id            String   @id @default(uuid())
  recipientId   String
  type          String // Assignment, ColumnChange, Comment, Deadline, Admin
  message       String
  relatedTaskId String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  recipient   User  @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  relatedTask Task? @relation(fields: [relatedTaskId], references: [id], onDelete: SetNull)

  @@index([recipientId, isRead])
}

// ─── Conversation Model ───────────────────────────────────────────────────────
// Represents either a project group chat or a direct message thread between two
// workspace members. One conversation per project (enforced by @@unique); DMs are
// scoped to a shared workspace.
model Conversation {
  id          String   @id @default(uuid())
  // "PROJECT" – all project members; "DIRECT" – exactly two workspace members
  type        String
  projectId   String?  @unique // set when type = PROJECT
  workspaceId String? // set for both types
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project      Project?                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace    Workspace?                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     ChatMessage[]

  @@index([workspaceId])
}

// ─── ConversationParticipant Model ───────────────────────────────────────────
model ConversationParticipant {
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

// ─── ChatMessage Model ────────────────────────────────────────────────────────
// A single message within a conversation. Soft-deleted messages retain the row
// so the thread history is not disrupted.
model ChatMessage {
  id             String @id @default(uuid())
  conversationId String
  senderId       String

  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete; content replaced by "[deleted]" on read

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([conversationId, createdAt])
}
